---
interface Props {
  /** Section label shown in small caps above the title, e.g. "blog", "post" */
  section?: string;
  /** The main title, rendered in bold mono */
  title: string;
  /** Optional small subtitle below the title */
  subtitle?: string;
}

const { section, title, subtitle } = Astro.props;
---

<header class="page-header">
  {section && <div class="page-section">{section}</div>}
  <h1 class="page-title">{title}</h1>
  {subtitle && <p class="page-subtitle">{subtitle}</p>}
  <slot name="meta" />
</header>

<style>
  .page-header {
    margin-top: 1.5rem;
    margin-bottom: 1.75rem;
  }
  .page-section {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in oklch, var(--orange) 90%, transparent);
    margin-bottom: 0.5rem;
  }
  .page-title {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: clamp(1.75rem, 1.3rem + 1.6vw, 2.4rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--primary);
    margin: 0;
  }
  .page-subtitle {
    font-family: var(--font-mono);
    color: var(--text-muted);
    margin: 0.4rem 0 0 0;
    font-size: 1rem;
    letter-spacing: 0.01em;
  }
</style>
