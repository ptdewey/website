---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getLocalBlogEntries, type BlogEntry } from '../../lib/blog-entries';

const posts = await getLocalBlogEntries();

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-CA', {
    year: 'numeric', month: '2-digit', day: '2-digit', timeZone: 'UTC',
  });

const byYear = new Map<number, BlogEntry[]>();
for (const post of posts) {
  const y = post.date.getUTCFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(post);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<Layout title="Blog — Patrick Dewey">
  <div class="almanac">
    <PageHeader title="blog" subtitle={`${posts.length} post${posts.length === 1 ? '' : 's'} since 2024`} />

    <div data-blog-index>
      {years.map(year => (
        <section class="year-group" data-year={year}>
          <div class="year-rule">
            <span class="year">{year}</span>
            <span class="line" aria-hidden="true"></span>
            <span class="count" data-year-count>{byYear.get(year)!.length}</span>
          </div>
          <div data-year-entries>
            {byYear.get(year)!.map(post => (
              <article class="post-entry" data-entry-date={post.date.toISOString()}>
                <time datetime={post.date.toISOString()} class="post-date">
                  {fmtDate(post.date)}
                </time>
                <div class="post-meta">
                  <a href={post.href} class="post-title">{post.title}</a>
                  {post.tags.length > 0 && (
                    <div class="post-tags">
                      {post.tags.slice(0, 4).map(tag => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>

    <footer class="blog-foot">
      <a href="/rss.xml">[subscribe via rss]</a>
    </footer>
  </div>
</Layout>

<style is:global>
  [data-blog-index] .year-group + .year-group { margin-top: 2.5rem; }

  .blog-foot {
    margin-top: 2.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--rule-color);
    font-size: 0.95rem;
    color: var(--text-dim);
  }
  .blog-foot a {
    color: var(--green);
    text-decoration: none;
  }
  .blog-foot a:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-decoration-color: var(--orange);
  }

  [data-blog-index] .year-rule {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.5ch;
    align-items: center;
    margin-bottom: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    letter-spacing: 0.08em;
  }
  [data-blog-index] .year-rule .year {
    color: var(--orange);
    font-weight: 700;
  }
  [data-blog-index] .year-rule .line {
    height: 1px;
    background: var(--rule-color);
  }
  [data-blog-index] .year-rule .count {
    color: var(--text-dim);
    font-size: 0.88rem;
  }

  [data-blog-index] .post-entry {
    display: grid;
    grid-template-columns: 13ch 1fr;
    gap: 2ch;
    align-items: baseline;
    padding: 0.55rem 0;
  }
  [data-blog-index] .post-date {
    font-family: var(--font-mono);
    color: var(--text-muted);
    font-size: 1rem;
    font-variant-numeric: tabular-nums;
  }
  [data-blog-index] .post-title {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 1.1rem;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--primary);
    text-decoration: none;
  }
  [data-blog-index] .post-title:hover {
    color: var(--green);
  }
  [data-blog-index] .post-meta { display: flex; flex-direction: column; gap: 0.3rem; }
  [data-blog-index] .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75ch;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--text-dim);
  }
  [data-blog-index] .tag::before { content: '#'; opacity: 0.5; }
  [data-blog-index] .source { color: var(--teal, var(--text-muted)); }

  @media (max-width: 30rem) {
    [data-blog-index] .post-entry { grid-template-columns: 1fr; gap: 0.3rem; }
    [data-blog-index] .post-date { font-size: 0.92rem; }
  }
</style>

<script>
  import '../../scripts/blog-externals';
</script>
