---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-CA', {
    year: 'numeric', month: '2-digit', day: '2-digit', timeZone: 'UTC',
  });

const bskyUri = post.data.bluesky_link;
const wordCount = post.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readMin = Math.max(1, Math.round(wordCount / 220));
---

<Layout title={`${post.data.title} — Patrick Dewey`} description={post.data.description} atprotoDocURI={bskyUri}>
  <article class="post">
    <PageHeader title={post.data.title}>
      <div slot="meta" class="post-meta-strip">
        <span class="meta-item">
          <span class="meta-label">date</span>
          <time datetime={post.data.date.toISOString()}>{fmtDate(post.data.date)}</time>
        </span>
        <span class="meta-sep" aria-hidden="true">·</span>
        <span class="meta-item">
          <span class="meta-label">read</span>
          <span>~{readMin} min</span>
        </span>
        {post.data.tags && post.data.tags.length > 0 && (
          <>
            <span class="meta-sep" aria-hidden="true">·</span>
            <span class="meta-item meta-tags">
              <span class="meta-label">tags</span>
              <span>{post.data.tags.join(', ')}</span>
            </span>
          </>
        )}
      </div>
    </PageHeader>

    <div class="post-body">
      <Content />
    </div>

    <aside class="comments-box" aria-label="comments">
      <div class="comments-header">
        <span class="comments-label">comments</span>
        <span class="comments-source">via bluesky</span>
      </div>
      <div id="comments"></div>
    </aside>
  </article>
</Layout>

<style>
  .post { font-family: var(--font-mono); }

  .post-meta-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.75ch;
    margin-top: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--rule-color);
    font-family: var(--font-mono);
    font-size: 0.92rem;
    color: var(--text-muted);
  }
  .meta-item { display: inline-flex; align-items: baseline; gap: 0.5ch; }
  .meta-label {
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.8rem;
  }
  .meta-sep {
    color: var(--text-dim);
  }
  .meta-tags { flex-wrap: wrap; }

  .post-body {
    max-width: 70ch;
    font-family: var(--font-mono);
    font-size: 1.0625rem;
    line-height: 1.7;
  }
  .post-body :global(h1),
  .post-body :global(h2),
  .post-body :global(h3),
  .post-body :global(h4) {
    font-family: var(--font-mono);
    font-weight: 700;
    letter-spacing: -0.015em;
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }
  .post-body :global(h2) { font-size: 1.45rem; color: var(--orange); }
  .post-body :global(h3) { font-size: 1.22rem; color: var(--red); }
  .post-body :global(h4) { font-size: 1.08rem; color: var(--yellow); }

  .post-body :global(p) { margin-block: 1rem; }
  .post-body :global(a) {
    color: var(--green);
    text-decoration-color: color-mix(in oklch, var(--green) 40%, transparent);
  }

  .post-body :global(img) {
    border: 1px solid color-mix(in oklch, var(--orange) 60%, transparent);
    border-radius: 2px;
  }

  .post-body :global(blockquote) {
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 1rem;
    color: var(--text-muted);
    background: color-mix(in oklch, var(--primary) 6%, var(--background));
    padding: 0.75rem 1.25rem;
    border: none;
    border-radius: 2px;
    margin: 1.25rem 0;
  }
  .post-body :global(blockquote p) { margin-block: 0.4rem; }
  .post-body :global(blockquote p:first-child) { margin-top: 0; }
  .post-body :global(blockquote p:last-child) { margin-bottom: 0; }

  .post-body :global(pre) {
    font-size: 0.92rem;
    padding: 0.9rem 1.1rem;
    border-radius: 2px;
    border: 1px solid var(--rule-color);
  }
  .post-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.92em;
  }
  .post-body :global(:not(pre) > code) {
    background: color-mix(in oklch, var(--primary) 10%, var(--background));
    padding: 0.1em 0.4ch;
    border-radius: 2px;
  }

  .post-body :global(hr) {
    border: 0;
    border-top: 1px solid var(--rule-color);
    margin-block: 2rem;
  }

  .post-body :global(table) {
    font-size: 0.95rem;
    border-collapse: collapse;
  }
  .post-body :global(th),
  .post-body :global(td) {
    padding: 0.4rem 1ch;
    border-bottom: 1px solid var(--rule-color);
  }

  .post-body :global(.footnotes) {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid var(--rule-color);
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  .comments-box {
    margin-top: 3.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--rule-color);
  }
  .comments-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1ch;
    margin-bottom: 1rem;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .comments-label { color: var(--orange); font-weight: 700; }
  .comments-source {
    color: var(--text-dim);
  }
</style>

<script is:inline src="/bluesky-comments.js"></script>
<script is:inline define:vars={{ bskyUri }}>
  if (bskyUri) {
    BlueskyComments('#comments', { uri: bskyUri });
  } else {
    BlueskyComments('#comments', { author: 'pdewey.com' });
  }
</script>
