---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { featured, other, contributions, type Project } from '../lib/projects';

const sections: Array<{ title: string; items: Project[] }> = [
  { title: 'featured', items: featured },
  { title: 'other', items: other },
  { title: 'contributions', items: contributions },
];
---

<Layout title="Projects — Patrick Dewey">
  <div class="almanac">
    <PageHeader
      title="projects"
      subtitle="things i've made and contributed to"
    />

    {sections.map(({ title, items }) => (
      <section class="proj-group">
        <div class="group-head">
          <span class="group-name">{title}</span>
          <span class="group-line" aria-hidden="true"></span>
          <span class="group-count">{items.length}</span>
        </div>
        <dl class="proj-list">
          {items.map(p => (
            <div class="proj-entry">
              <dt>
                <a href={p.href}>{p.name}</a>
              </dt>
              <dd>{p.desc}</dd>
            </div>
          ))}
        </dl>
      </section>
    ))}
  </div>
</Layout>

<style>
  .proj-group + .proj-group { margin-top: 2.75rem; }

  .group-head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.5ch;
    align-items: center;
    margin-bottom: 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    letter-spacing: 0.08em;
  }
  .group-name {
    color: var(--orange);
    font-weight: 700;
    text-transform: lowercase;
  }
  .group-line {
    height: 1px;
    background: var(--rule-color);
  }
  .group-count {
    color: var(--text-dim);
    font-size: 0.88rem;
  }

  .proj-list {
    margin: 0;
    font-family: var(--font-mono);
  }
  .proj-entry {
    display: grid;
    grid-template-columns: 24ch 1fr;
    gap: 2ch;
    align-items: baseline;
    padding: 0.5rem 0;
  }
  .proj-entry dt {
    margin: 0;
  }
  .proj-entry dt a {
    color: var(--green);
    font-weight: 600;
    text-decoration: none;
    word-break: break-word;
  }
  .proj-entry dt a:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-decoration-color: var(--orange);
  }
  .proj-entry dd {
    margin: 0;
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  @media (max-width: 36rem) {
    .proj-entry {
      grid-template-columns: 1fr;
      gap: 0.2rem;
      padding: 0.65rem 0;
    }
    .proj-entry dd { font-size: 0.94rem; }
  }
</style>
