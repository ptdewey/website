---
import Layout from '../layouts/Layout.astro';
import { revision } from '../lib/revision';
import { DID } from '../lib/atproto';
import { featured } from '../lib/projects';
import { getLocalBlogEntries } from '../lib/blog-entries';

const nowHeadline = "What I'm up to now";

const posts = await getLocalBlogEntries();
const latestPost = posts[0];
const recentPosts = posts.slice(0, 3);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-CA', {
    year: 'numeric', month: '2-digit', day: '2-digit', timeZone: 'UTC',
  });

const today = fmtDate(new Date());
---

<Layout title="Patrick Dewey">
  <div class="almanac">
    <section class="masthead">
      <h1 class="wordmark">patrick dewey</h1>
      <div class="meta-strip">
        <span>a personal almanac</span>
        <span>
          {revision.short && <><span class="rev">rev: {revision.short}</span><span class="sep"> / </span></>}
          <time datetime={new Date().toISOString().slice(0, 10)}>{today}</time>
        </span>
      </div>
    </section>

    <hr class="rule" />

    <section class="about" aria-label="about">
      <div class="section-head">
        <span>about</span>
      </div>
      <p class="blurb">
        Hello, I'm Patrick, a backend software engineer who loves learning new 
        technologies, building dev tools, and building on the open web. 
        I'm currently working on <a href="https://alpha.arabica.social">arabica.social</a>,
        a social coffee brew logging site, built on <a href="https://atproto.com">atproto</a>.
      </p>
    </section>

    <hr class="rule" />

    <section class="dashboard" aria-label="current state">
      <div class="section-head">
        <span>recent</span>
      </div>
      <div class="row">
        <span class="label">/now</span>
        <span><a href="/now">{nowHeadline}</a></span>
      </div>
      {latestPost && (
        <div class="row" data-latest-post data-latest-date={latestPost.date.toISOString()}>
          <span class="label">latest post</span>
          <div class="value-stack">
            <a
              href={latestPost.href}
              class="primary-value"
              data-latest-link
            >{latestPost.title}</a>
            <span class="secondary-value" data-latest-secondary>
              <time datetime={latestPost.date.toISOString()}>{fmtDate(latestPost.date)}</time>
            </span>
          </div>
        </div>
      )}
      <div class="row" data-recent="play">
        <span class="label">recent play</span>
        <div class="value-stack">
          <a href="/music" class="primary-value track-name" data-play-track>…</a>
          <span class="secondary-value" data-play-secondary>…</span>
        </div>
      </div>
      <div class="row" data-recent="brew">
        <span class="label">recent brew</span>
        <div class="value-stack">
          <a href="/coffee" class="primary-value bean-name" data-brew-bean>…</a>
          <span class="secondary-value" data-brew-secondary>…</span>
        </div>
      </div>
    </section>

    <hr class="rule" />

    <section aria-label="blog">
      <div class="section-head">
        <span>blog</span>
        <span class="head-actions">
          <a href="/rss.xml" class="more">[rss]</a>
          <a href="/blog" class="more">[view all]</a>
        </span>
      </div>
      <div data-blog-list>
        {recentPosts.map(post => (
          <div class="entry" data-entry-date={post.date.toISOString()}>
            <time datetime={post.date.toISOString()}>{fmtDate(post.date)}</time>
            <a href={post.href}>{post.title}</a>
          </div>
        ))}
      </div>
    </section>

    <hr class="rule" />

    <section aria-label="projects">
      <div class="section-head">
        <span>projects</span>
        <a href="/projects" class="more">[view all]</a>
      </div>
      {featured.map(p => (
        <div class="entry">
          <a class="key project-key" href={p.href}>{p.name}</a>
          <span>{p.desc}</span>
        </div>
      ))}
    </section>

    <hr class="rule" />

    <section class="identity" aria-label="identity">
      <div class="section-head">
        <span>identity</span>
      </div>
      <div class="entry">
        <span class="key">atproto</span>
        <span class="value-stack">
          <span class="at-uri">at://{DID}</span>
          <a href="https://bsky.app/profile/pdewey.com" class="primary-value">@pdewey.com</a>
        </span>
      </div>
      <div class="entry">
        <span class="key">github</span>
        <span><a href="https://github.com/ptdewey">ptdewey</a></span>
      </div>
    </section>
  </div>
</Layout>

<style>
  .masthead { margin-bottom: 0.75rem; }
  .wordmark-dim {
    color: var(--text-dim);
    font-weight: 400;
  }

  /* Two-line stack for dashboard rows with multiple data points.
     Primary sits on the value baseline; secondary is muted and smaller
     so wrap behavior is predictable (no mid-line color jumps). */
  .value-stack {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }
  .primary-value {
    color: var(--link-color);
    overflow-wrap: anywhere;
  }
  .secondary-value {
    color: var(--text-muted);
    font-size: 0.88rem;
  }
  .sep { color: var(--text-dim); }

  .project-key {
    color: var(--green);
    font-weight: 600;
  }

  .source-tag {
    color: var(--text-muted);
    font-size: 0.88em;
  }

  .bean-name { font-weight: 600; }
  .track-name { font-weight: 600; }
  .brew-method {
    color: var(--teal);
    letter-spacing: 0.04em;
  }

  .at-uri {
    color: var(--text-muted);
    word-break: break-all;
  }

  .identity { margin-top: 0.5rem; }

  .blurb {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    max-width: 65ch;
    margin: 0;
  }

  .head-actions {
    display: inline-flex;
    gap: 1.25ch;
  }

  /* Tighten prose's default margins inside the almanac */
  :global(.prose) .almanac :where(p, ul, ol) {
    margin: 0;
  }
</style>

<script>
  import '../scripts/home-recents';
</script>
