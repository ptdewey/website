---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Music">
  <div class="almanac">
    <section class="masthead">
      <h1 class="page-title">listening log</h1>
      <div class="meta-strip">
        <span>plays from <a href="https://teal.fm">teal.fm</a></span>
      </div>
    </section>

    <hr class="rule" />

    <p class="intro">
      Plays scrobbled by <a href="https://github.com/teal-fm/piper">piper</a> and written to my PDS. Fetched at read time, so the now-playing line updates as I listen.
    </p>

    <div id="now-playing" class="now-playing hidden">
      <span class="np-label">now playing</span>
      <div class="log-value">
        <div>
          <span id="np-track" class="np-track"></span>
          <span class="np-sep" aria-hidden="true">&middot;</span>
          <span id="np-artist" class="np-artist"></span>
        </div>
        <div id="np-release" class="np-release"></div>
        <div class="np-progress" aria-hidden="true">
          <span class="np-bar"><span id="np-bar-filled" class="np-bar-filled"></span><span id="np-bar-empty" class="np-bar-empty"></span></span>
          <span id="np-time" class="np-time"></span>
        </div>
      </div>
    </div>

    <hr class="rule" />

    <div class="log-col-head" aria-hidden="true">
      <span>when</span>
      <span>track &middot; artist &middot; release</span>
    </div>

    <div id="play-list" class="log-body">
      <p class="log-msg">Fetching plays&hellip;</p>
    </div>
  </div>

  <template id="play-tmpl">
    <article class="log-entry play-entry">
      <time class="log-date"></time>
      <div class="log-value">
        <a class="play-track" target="_blank" rel="noopener"></a>
        <div class="play-artist"></div>
        <div class="play-release"></div>
        <div class="log-rkey play-rkey"></div>
      </div>
    </article>
  </template>

  <noscript>
    <p>Enable JavaScript to view plays, or visit <a href="https://teal.fm">teal.fm</a>.</p>
  </noscript>
</Layout>

<script>
  import '../scripts/music';
</script>
